name: Scheduled rebuild

# The /favorites page is prerendered at build time and pulls books from
# Goodreads. This workflow triggers a fresh Cloudflare Pages build on a
# schedule so the baked-in Books and "Recently Read" sections stay current.
#
# Setup (one time):
#   1. In Cloudflare Pages > this project > Settings > Builds & deployments,
#      create a "Deploy hook" (pick the production branch).
#   2. Copy the hook URL into a GitHub Actions repo secret named
#      CLOUDFLARE_DEPLOY_HOOK_URL (Settings > Secrets and variables > Actions).

on:
  schedule:
    - cron: "0 13 * * *" # daily at 13:00 UTC (~6am America/Los_Angeles)
  workflow_dispatch: {}

jobs:
  trigger-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger Cloudflare Pages deploy hook
        env:
          DEPLOY_HOOK_URL: ${{ secrets.CLOUDFLARE_DEPLOY_HOOK_URL }}
        run: |
          if [ -z "$DEPLOY_HOOK_URL" ]; then
            echo "::error::CLOUDFLARE_DEPLOY_HOOK_URL secret is not set." >&2
            exit 1
          fi
          curl -fsS -X POST "$DEPLOY_HOOK_URL"
          echo "Triggered Cloudflare Pages rebuild."
