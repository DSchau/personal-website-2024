---
import { Picture } from 'astro:assets'
import styles from './favorites.module.css'

import FancyLink from '../fancy-link/fancy-link.astro'

const { list } = Astro.props

function isRemoteImage(image: any): boolean {
  return typeof image === 'string' && image.startsWith('http')
}
---
<ul class={styles.container}>
  {
    list.map((item: any) => (
      <li class={styles.item}>
          {item.image && (
            isRemoteImage(item.image)
              ? <img src={item.image} height={200} alt={`${item.title}${item.subtitle ? ` by ${item.subtitle}` : ''}`} loading="lazy" />
              : <Picture src={item.image} formats={['avif', 'webp']} height={200} alt={`${item.title}${item.subtitle ? ` by ${item.subtitle}` : ''}`} loading="lazy" />
          )}
          <FancyLink href={item.hyperlink} class={styles.title}>
            {item.title}
            {item.subtitle && <span class={styles.subtitle}>{item.subtitle}</span>}
          </FancyLink>
      </li>
    ))
  }
</ul>