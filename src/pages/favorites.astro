---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import FavoritesComponent from '@/components/favorites/favorites.astro'
import { getFavoriteBooks, getRecentlyRead, toFavoriteItem } from '@/lib/goodreads'

export const prerender = true

const favorites = await getCollection('favorites')
	.then(data => data[0].data)

const allFavorites = Object.keys(favorites)
	.filter(key => key !== 'books')
	.map(favorite => ({
		title: favorite.slice(0, 1).toUpperCase() + favorite.slice(1),
		list: (favorites as any)[favorite]
	}))

const [favoriteBooks, recentlyRead] = await Promise.all([
	getFavoriteBooks(),
	getRecentlyRead(10)
])

const favoriteBooksList = favoriteBooks.map(toFavoriteItem)
const recentlyReadList = recentlyRead.map(toFavoriteItem)
---
<style>
	section {
		margin: var(--padding-lg) 0;
		padding: var(--padding-lg) 0;
	}

	section > p {
		margin: 0 auto;
		width: var(--content-width);

		padding: var(--padding-md) var(--padding-lg);
	}

	.images {
		display: grid;
		grid-template-columns: 1fr;
	}

	.images > .image {
		padding: var(--padding-s);
	}

	.images img {
		max-height: 450px;
		height: 100%;
		border-radius: var(--padding-lg);
	}

	@media only screen and (min-width: var(--breakpoint-md)) {
		.images {
			grid-template-columns: repeat(2, 1fr);
		}
	}

</style>

<Layout title="Favorites &#x2022;&#xa0;Films, Series, Albums, Songs, and Games" byline="My favorite things" copy="These are some of my favorite things. Books, movies, series, albums, songs, and games; my top five favorites. You can learn a lot about a person by what they appreciate, what they enjoy, and what matters to them, so I hope this reveals a bit more about me.">
	{favoriteBooksList.length > 0 && (
		<section id="books">
			<h3 class="section-title">Books</h3>
			<FavoritesComponent list={favoriteBooksList} />
		</section>
	)}
	{allFavorites.map(({ title, list }) => (
		<section id={title.toLowerCase()}>
			<h3 class="section-title">{title}</h3>
			<FavoritesComponent list={list} />
		</section>
	))}
	{recentlyReadList.length > 0 && (
		<section id="recently-read">
			<h3 class="section-title">Recently Read</h3>
			<FavoritesComponent list={recentlyReadList} />
		</section>
	)}
</Layout>
